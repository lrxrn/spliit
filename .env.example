POSTGRES_PRISMA_URL=postgresql://postgres:1234@localhost
POSTGRES_URL_NON_POOLING=postgresql://postgres:1234@localhost

# Public URL this instance is reachable at. Defaults to http://localhost:3000.
# BASE_URL=http://localhost:3000

# Default currency pre-selected when creating a new group. Defaults to USD.
# DEFAULT_CURRENCY_CODE=EUR

# ─── Accounts & authentication ───────────────────────────────────────────────
# URL of the managed Better Auth instance. Defaults to https://auth.lrxrn.dev
# BETTER_AUTH_URL=https://auth.lrxrn.dev

# ─── Landing page text overrides (optional) ──────────────────────────────────
# Override the default i18n text on the landing page at runtime.
# LANDING_TITLE=
# LANDING_DESCRIPTION=
# LANDING_CTA=

# ─── Opt-in features ─────────────────────────────────────────────────────────
# See the README for required dependencies of each feature.

# Attach images to expenses.
# Choose storage provider: s3 (default) or r2
# ENABLE_EXPENSE_DOCUMENTS=true
# STORAGE_PROVIDER=s3

# S3 storage (default when STORAGE_PROVIDER=s3):
# S3_UPLOAD_KEY=
# S3_UPLOAD_SECRET=
# S3_UPLOAD_BUCKET=
# S3_UPLOAD_REGION=
# S3_UPLOAD_ENDPOINT=   # only needed for non-AWS S3 providers

# Cloudflare R2 storage (when STORAGE_PROVIDER=r2):
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# Create expenses by scanning receipts (requires OpenAI and expense documents):
# ENABLE_RECEIPT_EXTRACT=true
# OPENAI_API_KEY=

# Auto-suggest expense category from title (requires OpenAI):
# ENABLE_CATEGORY_EXTRACT=true
# OPENAI_API_KEY=

# OpenAI options (shared by receipt and category features):
# OPENAI_BASE_URL=       # custom/self-hosted endpoint; defaults to OpenAI
# OPENAI_MODEL_RECEIPT_EXTRACT=gpt-5.4-nano
# OPENAI_MODEL_CATEGORY_EXTRACT=gpt-5.4-nano
